# LegalForge Backend Configuration
# Copy this file to .env and fill in your credentials

# ─── Email (Gmail App Password) ────────────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password

# ─── Internal Core ─────────────────────────────────────────────────────────────
APP_CORE_TOKEN=your-core-token

# ─── Secure Storage (Supabase) ────────────────────────────────────────────────
STORAGE_SERVICE_KEY=your-storage-service-key

# ─── SaaS Notification / Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key

# ─── Scrapling Web Research ──────────────────────────────────────────────────
# Scrapling fetches and extracts content from web pages for legal research
SCRAPLING_FETCH_TIMEOUT=15
SCRAPLING_RESULTS_PER_QUERY=5

# ─── Ollama (Local LLM) ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BACKUP_MODEL=llama3.1

# ─── NVIDIA API (Gemma 3n) ──────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_PRIMARY_MODEL=google/gemma-3n-e2b-it
NVIDIA_RESEARCH_MODEL=google/gemma-3n-e2b-it
NVIDIA_DOCUMENT_MODEL=google/gemma-3n-e2b-it

# ─── AI Provider ─────────────────────────────────────────────────────────────
AI_PROVIDER=nvidia
AI_ENABLE_MANAGED_MODELS=true
AI_ENABLE_LOCAL_FALLBACK=true
AI_HTTP_TIMEOUT_SECONDS=300

# ─── Neural Audit ────────────────────────────────────────────────────────────
LEGAL_PAPER_ENABLE_NEURAL_AUDIT=false
LEGAL_PAPER_NEURAL_TIMEOUT_SECONDS=45

# ─── OpenRouter (Alternative AI) ─────────────────────────────────────────────
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_PRIMARY_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─── Minimax (Alternative AI) ────────────────────────────────────────────────
# MINIMAX_API_KEY=your-minimax-key
# MINIMAX_PRIMARY_MODEL=mistral-7b

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ─── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production
